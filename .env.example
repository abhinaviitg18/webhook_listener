PORT=8080
USE_IN_MEMORY_STORE=true
VERIFY_HTC_SIGNATURE=false
DETERMINISTIC_ONLY_TYPE_KEYS=ai-recruiter-inbox-message

# TiDB / MySQL
TIDB_DSN=root:@tcp(127.0.0.1:4000)/hookweb?parseTime=true

# ScaleKit (set after creating ScaleKit tenant with 7204909316@agentmail.to)
SCALEKIT_BASE_URL=
SCALEKIT_API_KEY=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
SCALEKIT_REDIRECT_URI=
APP_SESSION_SECRET=
PUBLIC_BASE_URL=https://app.agenthook.store

# Pinecone (set after creating a NEW Pinecone project with 7204909316@agentmail.to)
PINECONE_API_KEY=
PINECONE_INDEX_URL=
PINECONE_NAMESPACE=hookweb

# LLM provider (Groq, Cerebras, or OpenRouter compatible)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Auto type resolver providers (used for low-confidence classification)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=

# Auto-promote (validated -> shadow -> active)
AUTOPROMOTE_ENABLED=true
AUTOPROMOTE_MIN_CONFIDENCE=0.88
AUTOPROMOTE_VALIDATED_TO_SHADOW=2
AUTOPROMOTE_SHADOW_TO_ACTIVE=3
AUTOPROMOTE_MIN_SUCCESS_RATE=0.90

# Telegram
TELEGRAM_BOT_TOKEN=
